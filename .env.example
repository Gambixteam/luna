# Public application URL
NEXT_PUBLIC_APP_URL=https://luna.gambix.io

# Supabase project. The anon key is intentionally used by authenticated browser clients;
# the service role key remains server-only for billing, OAuth storage and Gambix administration.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter. Generation falls back to rules-based outputs when the API key is absent.
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/auto
OPENROUTER_SITE_URL=https://luna.gambix.io
OPENROUTER_APP_NAME=Luna by Gambix

# Google OAuth. Register the callback URL exactly in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://luna.gambix.io/api/integrations/google/callback
GOOGLE_OAUTH_STATE_SECRET=replace-with-at-least-32-random-characters
INTEGRATION_ENCRYPTION_KEY=replace-with-64-hex-characters

# Comma-separated users allowed into /admin.
GAMBIX_ADMIN_EMAILS=

# Scheduled jobs and billing
CRON_SECRET=replace-with-at-least-24-characters
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
