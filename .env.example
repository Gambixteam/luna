# Public application URL
NEXT_PUBLIC_APP_URL=https://luna.gambix.io

# Supabase project. The anon key is intentionally used by authenticated browser clients;
# the service role key remains server-only for Stripe and controlled administrative jobs.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter. Generation falls back to rules-based outputs when the API key is absent.
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/auto
OPENROUTER_SITE_URL=https://luna.gambix.io
OPENROUTER_APP_NAME=Luna by Gambix

# Scheduled jobs and billing
CRON_SECRET=replace-with-at-least-24-characters
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
